  "intro": {
    "title": "Introduction to Cantonese",
    "subtitle": "Heritage, Features, and Cultural Power",
    "whatIsTitle": "What is Cantonese?",
    "whatIsContent": "Cantonese (粵語/廣東話) is a Sinitic language originating from the Canton (Guangzhou) region of China. Spoken by over 80 million people globally, it is the official language of Hong Kong and Macau, and the historic lingua franca of Chinese diaspora communities worldwide.",
    "historyTitle": "A Rich Historical Heritage",
    "historyContent": "Cantonese is renowned for retaining ancient features of Middle Chinese dating back to the Tang Dynasty (618–907 AD). While Mandarin has evolved significantly over time, Cantonese preserves historical pronunciations, making it the perfect language to read and experience classical Chinese poetry with its original rhymes and rhythm.",
    "featuresTitle": "Linguistic Characteristics",
    "feature1Title": "The Music of Tones",
    "feature1Content": "Cantonese features 6 standard tones (or 9 including historical entering tones ending in p, t, k). This tonal variety gives the language a highly musical, melodic flow that is expressive and rhythmic.",
    "feature2Title": "Preserved Codas",
    "feature2Content": "Unlike modern Mandarin, Cantonese preserves final consonant stops (-p, -t, -k) and final nasal consonants (-m, -n, -ng). This structural richness makes Cantonese phonetically distinct and vibrant.",
    "feature3Title": "Rich Slang & Colloquialisms",
    "feature3Content": "Cantonese is filled with unique idioms and colorful colloquial expressions. It has a high degree of divergence between its written formal style and its dynamic, highly popular spoken language.",
    "funFactsTitle": "Fun & Motivating Facts",
    "fact1": "Cantonese is the key to classic Canto-pop music and Hong Kong cinema—from Wong Kar-wai films to Stephen Chow comedies and Bruce Lee action.",
    "fact2": "The popular English phrase 'add oil' (a direct translation of 加油 gaa1 jau2) was officially added to the Oxford English Dictionary due to its widespread Cantonese usage.",
    "fact3": "Classical Tang Dynasty poems rhyme perfectly when read in Cantonese, whereas they lose their rhyme schemes when read in modern Mandarin."
  },
