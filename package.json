{
  "name": "cantonese-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint:content && tsc && vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/index.html', 'dist/404.html')\"",
    "preview": "vite preview",
    "test.e2e": "cypress run",
    "test.e2e.ci": "start-server-and-test \"vite preview --port 4173\" http://localhost:4173/cantonese_app/ \"cypress run\"",
    "test.unit": "vitest",
    "lint": "eslint",
    "lint:content": "node scripts/validate-lessons.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/status-bar": "^8.0.2",
    "@ionic/react": "^8.8.11",
    "@sentry/react": "^10.59.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "ionicons": "^8.0.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.17.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^22.1.0",
    "mitata": "^1.0.34",
    "start-server-and-test": "^2.1.5",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "description": "An Ionic project"
}
